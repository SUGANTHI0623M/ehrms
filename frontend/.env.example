# Environment Variables Example
# Copy this file to .env for local development
# Copy this file to .env.production for production builds

# API Base URL (used by RTK Query, LMS, and other services)
# Local backend:  http://localhost:7001/api
# Production:     https://hrms.askeva.net/api
VITE_API_URL=http://localhost:7001/api

# Optional: Socket server (defaults to same host as VITE_API_URL, or localhost:9000)
# VITE_SOCKET_URL=http://localhost:7001
