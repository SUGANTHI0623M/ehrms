# Use same MongoDB as app_backend (refer app_backend .env)
MONGODB_URI=mongodb+srv://boominathanaskeva_db_user:aaEaG4gSxM5EV6rM@cluster0.p508zsu.mongodb.net/hrms-development

# Redis + queue (required for 50+ users; run: npm run worker)
USE_REDIS=true
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_NAME=monitoring_processing_queue

# Scaling (defaults support ~200 users behind one IP; tune if needed)
# USE_REDIS=true recommended for 50+ users (offloads activity/screenshot processing to worker)
MONGODB_POOL_SIZE=100
WORKER_CONCURRENCY=16
INLINE_CONCURRENCY=8
UPLOAD_RATE_LIMIT_PER_MIN=1200
HEARTBEAT_RATE_LIMIT_PER_MIN=120
SETTINGS_RATE_LIMIT_PER_MIN=120
SETTINGS_CACHE_TTL_SEC=90


NODE_ENV=production

JWT_SECRET=AEvaHRMS@123
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

